{
  "name": "naruto-shelter-map",
  "version": "1.0.0",
  "private": true,
  "description": "徳島県鳴門市とその隣接地域の避難所を地図上に可視化するPWAアプリ",
  "author": "Yusaku Matsukawa",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage --coverage.provider=v8 --coverage.include=src/hooks/useShelters.ts --coverage.include=src/hooks/useFilteredShelters.ts --coverage.thresholds.lines=100 --coverage.thresholds.branches=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100",
    "test:e2e": "playwright test",
    "validate:shelters": "tsx scripts/validate-shelters.ts",
    "geocode:shelters": "tsx scripts/geocode-shelters.ts",
    "release:patch": "pnpm version patch --git-tag-version true",
    "release:minor": "pnpm version minor --git-tag-version true",
    "release:major": "pnpm version major --git-tag-version true",
    "release:check": "node -e \"const pkg = require('./package.json'); const tag = require('child_process').execSync('git describe --tags --abbrev=0 2>/dev/null || echo', { encoding: 'utf-8' }).trim().replace(/^v/, ''); if (tag && pkg.version !== tag) { console.error('❌ Version mismatch: package.json=' + pkg.version + ', tag=' + tag); process.exit(1); } else { console.log('✅ Version matches: ' + pkg.version); }\""
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.22.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "volta": {
    "node": "24.14.1"
  }
}
